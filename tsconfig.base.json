{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowJs": false,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@campusflow/shared": ["packages/shared/src/index.ts"],
      "@campusflow/shared/*": ["packages/shared/src/*"],
      "@campusflow/ui": ["packages/ui/src/index.ts"],
      "@campusflow/ui/*": ["packages/ui/src/*"]
    }
  }
}